# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (email notifications)
RESEND_API_KEY=

# Calendar embed for kickoff booking (Cal.com or Calendly URL, or any iframe-embeddable booking page)
# Leave empty to show a fallback "we will call you" CTA instead
NEXT_PUBLIC_CALENDAR_EMBED_URL=

# Twilio (admin SMS notification on new submission)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ADMIN_PHONE_NUMBER=

# Google Places (address autocomplete — leave empty to use plain text inputs)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
